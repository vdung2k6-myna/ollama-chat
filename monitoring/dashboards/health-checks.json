{
  "dashboard": {
    "id": null,
    "title": "Ollama Chat Health Checks",
    "tags": ["health-check", "ollama", "backend"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Health Check Success Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "health_check_success_rate",
            "legendFormat": "{{ path }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "yellow",
                  "value": 95
                },
                {
                  "color": "green",
                  "value": 99
                }
              ]
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Health Check Response Time",
        "type": "stat",
        "targets": [
          {
            "expr": "health_check_response_time_avg",
            "legendFormat": "{{ path }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": 0
                },
                {
                  "color": "yellow",
                  "value": 50
                },
                {
                  "color": "red",
                  "value": 100
                }
              ]
            },
            "unit": "ms",
            "min": 0
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Health Check Request Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(health_check_requests_total[5m])",
            "legendFormat": "{{ path }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "reqps",
            "min": 0
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Circuit Breaker Status",
        "type": "stat",
        "targets": [
          {
            "expr": "circuit_breaker_open",
            "legendFormat": "{{ path }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": 0
                },
                {
                  "color": "red",
                  "value": 1
                }
              ]
            },
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "Closed"
                  },
                  "1": {
                    "text": "Open"
                  }
                },
                "type": "value"
              }
            ]
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "Health Check Success Rate Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "health_check_success_rate",
            "legendFormat": "{{ path }}"
          }
        ],
        "yAxes": [
          {
            "min": 0,
            "max": 100,
            "unit": "percent"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Health Check Response Time Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "health_check_response_time_avg",
            "legendFormat": "{{ path }}"
          }
        ],
        "yAxes": [
          {
            "min": 0,
            "unit": "ms"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 7,
        "title": "Health Check Request Rate Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(health_check_requests_total[5m])",
            "legendFormat": "{{ path }}"
          }
        ],
        "yAxes": [
          {
            "min": 0,
            "unit": "reqps"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 8,
        "title": "Health Check Failure Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(health_check_failure_total[5m])",
            "legendFormat": "{{ path }}"
          }
        ],
        "yAxes": [
          {
            "min": 0,
            "unit": "reqps"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        }
      },
      {
        "id": 9,
        "title": "Ollama Service Status",
        "type": "table",
        "targets": [
          {
            "expr": "ollama_readiness_status",
            "legendFormat": "{{ path }}"
          },
          {
            "expr": "ollama_readiness_status_code",
            "legendFormat": "{{ path }}"
          },
          {
            "expr": "ollama_readiness_check_duration_seconds",
            "legendFormat": "{{ path }}"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {},
              "renameByName": {
                "Value #A": "Status",
                "Value #B": "Status Code",
                "Value #C": "Duration (s)"
              }
            }
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 24
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 1,
    "links": [
      {
        "title": "Ollama Chat Documentation",
        "url": "https://docs.ollama.chat",
        "type": "link",
        "icon": "doc"
      },
      {
        "title": "Health Check Troubleshooting",
        "url": "https://docs.ollama.chat/health-checks/troubleshooting",
        "type": "link",
        "icon": "bug"
      }
    ]
  }
}

---
# Alternative: Simple JSON dashboard for older Grafana versions
{
  "dashboard": {
    "title": "Ollama Chat Health Checks",
    "rows": [
      {
        "title": "Health Check Overview",
        "height": "250px",
        "panels": [
          {
            "title": "Success Rate",
            "type": "singlestat",
            "targets": [
              {
                "expr": "health_check_success_rate",
                "legendFormat": "{{ path }}"
              }
            ],
            "valueName": "current",
            "format": "percent",
            "thresholds": "95,99",
            "colors": ["red", "yellow", "green"],
            "span": 3
          },
          {
            "title": "Response Time",
            "type": "singlestat",
            "targets": [
              {
                "expr": "health_check_response_time_avg",
                "legendFormat": "{{ path }}"
              }
            ],
            "valueName": "current",
            "format": "ms",
            "thresholds": "50,100",
            "colors": ["green", "yellow", "red"],
            "span": 3
          },
          {
            "title": "Request Rate",
            "type": "singlestat",
            "targets": [
              {
                "expr": "rate(health_check_requests_total[5m])",
                "legendFormat": "{{ path }}"
              }
            ],
            "valueName": "current",
            "format": "reqps",
            "span": 3
          },
          {
            "title": "Circuit Breaker",
            "type": "singlestat",
            "targets": [
              {
                "expr": "circuit_breaker_open",
                "legendFormat": "{{ path }}"
              }
            ],
            "valueName": "current",
            "mappingType": 1,
            "valueMaps": [
              {"value": 0, "text": "Closed"},
              {"value": 1, "text": "Open"}
            ],
            "colors": ["green", "red"],
            "span": 3
          }
        ]
      },
      {
        "title": "Health Check Trends",
        "height": "250px",
        "panels": [
          {
            "title": "Success Rate Over Time",
            "type": "graph",
            "targets": [
              {
                "expr": "health_check_success_rate",
                "legendFormat": "{{ path }}"
              }
            ],
            "yAxes": [
              {
                "min": 0,
                "max": 100,
                "unit": "percent"
              }
            ],
            "span": 6
          },
          {
            "title": "Response Time Over Time",
            "type": "graph",
            "targets": [
              {
                "expr": "health_check_response_time_avg",
                "legendFormat": "{{ path }}"
              }
            ],
            "yAxes": [
              {
                "min": 0,
                "unit": "ms"
              }
            ],
            "span": 6
          },
          {
            "title": "Request Rate Over Time",
            "type": "graph",
            "targets": [
              {
                "expr": "rate(health_check_requests_total[5m])",
                "legendFormat": "{{ path }}"
              }
            ],
            "yAxes": [
              {
                "min": 0,
                "unit": "reqps"
              }
            ],
            "span": 6
          },
          {
            "title": "Failure Rate",
            "type": "graph",
            "targets": [
              {
                "expr": "rate(health_check_failure_total[5m])",
                "legendFormat": "{{ path }}"
              }
            ],
            "yAxes": [
              {
                "min": 0,
                "unit": "reqps"
              }
            ],
            "span": 6
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}

# Notes:
# - Import this JSON into Grafana to create the health check dashboard
