# Ollama API Configuration
OLLAMA_API_URL=http://localhost:11434

# Backend Server Configuration
HTTP_LOCAL_HOST=http://localhost
HTTP_LOCAL_PORT=5000

# Frontend Server (separate from backend)
FRONTEND_HOST=http://localhost
FRONTEND_PORT=3000

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# CORS Configuration for Render.com deployment
# Add your Render.com domains here for CORS support
# BACKEND_URL should point to your backend server
BACKEND_URL=http://localhost:5000

# Environment Variable
NODE_ENV=development